#!/usr/bin/env bash
# claude-remote — manage relay project Claude sessions with persisted desired-state.
#
# State file:  /var/lib/claude-remote/state.json
# Log file:    /var/log/claude-remote.log
#
# Usage: claude-remote <command> [args]   (see --help)

set -euo pipefail

CLAUDE_USER="claude"
CLAUDE_HOME="/home/${CLAUDE_USER}"
PROJECT_PREFIX="claude-"
STATE_DIR="/var/lib/claude-remote"
STATE_FILE="${STATE_DIR}/state.json"
LOG_FILE="/var/log/claude-remote.log"

# Root (operator) session — separate from projects. State lives under
# state.json's top-level "root" object; persistence is opt-in (set by
# `claude-remote root start` / `resume`, cleared by `root stop`).
ROOT_SESSION="claude-root"
ROOT_DIR="/root"
ROOT_CLAUDE_BIN="/root/.local/bin/claude"
ROOT_DEFAULT_LABEL="🛠️ 🌐 🧠 - Sysadmin (root)"

c_blue=$'\033[1;34m'
c_green=$'\033[1;32m'
c_red=$'\033[1;31m'
c_yellow=$'\033[1;33m'
c_reset=$'\033[0m'

die()      { printf '%serror:%s %s\n' "$c_red" "$c_reset" "$*" >&2; exit 1; }
say()      { printf '%s\n' "$*"; }
ts()       { date -u +%Y-%m-%dT%H:%M:%SZ; }
logmsg()   { printf '%s %s\n' "$(ts)" "$*" >> "$LOG_FILE" 2>/dev/null || true; }

require_root() { [[ $EUID -eq 0 ]] || die "must be run as root"; }

ensure_state() {
  install -d -m 0750 "$STATE_DIR"
  install -d -m 0755 "$(dirname "$LOG_FILE")"
  if [[ ! -e "$LOG_FILE" ]]; then
    : > "$LOG_FILE"
    chmod 0640 "$LOG_FILE"
  fi
  if [[ ! -f "$STATE_FILE" ]]; then
    echo '{"projects": {}}' > "$STATE_FILE"
    chmod 0640 "$STATE_FILE"
  fi
}

project_dir()     { printf '%s/%s' "$CLAUDE_HOME" "$1"; }
project_session() { printf '%s%s' "$PROJECT_PREFIX" "$1"; }
project_exists()  { [[ -d "$(project_dir "$1")" ]]; }

session_running() {
  sudo -u "$CLAUDE_USER" tmux has-session -t "$1" 2>/dev/null
}

#------------------------------------------------------------------------------
# State helpers (python3 for safe JSON)
#------------------------------------------------------------------------------

state_update() {
  # Usage: state_update <project> key=value [key=value ...]
  # Special value __delete__ removes the key.
  local project=$1; shift
  python3 - "$STATE_FILE" "$project" "$@" <<'PY'
import json, sys
state_file, project, *kvs = sys.argv[1:]
with open(state_file) as f:
    data = json.load(f)
proj = data.setdefault("projects", {}).setdefault(project, {})
for kv in kvs:
    k, _, v = kv.partition("=")
    if v == "__delete__":
        proj.pop(k, None)
    else:
        proj[k] = v
with open(state_file, "w") as f:
    json.dump(data, f, indent=2, sort_keys=True)
PY
}

state_get() {
  # Usage: state_get <project> <key>  →  prints value or empty
  python3 - "$STATE_FILE" "$1" "$2" <<'PY'
import json, sys
state_file, project, key = sys.argv[1:]
with open(state_file) as f:
    data = json.load(f)
print(data.get("projects", {}).get(project, {}).get(key, ""))
PY
}

state_projects() {
  python3 - "$STATE_FILE" <<'PY'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
for name in sorted(data.get("projects", {}).keys()):
    print(name)
PY
}

discover_projects() {
  [[ -d "$CLAUDE_HOME" ]] || return 0
  find "$CLAUDE_HOME" -mindepth 1 -maxdepth 1 -type d \
    ! -name '.*' -printf '%f\n' | sort
}

# Resolve the Remote Control session label for a project:
#   1. config.json "session_label" if set
#   2. "🛠️🌐 - <default-host-name> Sysadmin"
#   3. "🛠️🌐 - <project> Sysadmin" (capitalized)
session_label() {
  local project=$1
  local cfg="$(project_dir "$project")/config.json"
  python3 - "$cfg" "$project" <<'PY'
import json, sys
cfg_path, project = sys.argv[1:]
default_template = f"🛠️🌐 - {project[:1].upper() + project[1:]} Sysadmin"
try:
    with open(cfg_path) as f:
        cfg = json.load(f)
except Exception:
    print(default_template)
    sys.exit()
if cfg.get("session_label"):
    print(cfg["session_label"])
    sys.exit()
hosts = cfg.get("hosts", [])
default_host = next((h for h in hosts if h.get("default")), hosts[0] if hosts else None)
ref = (default_host or {}).get("name") or project
print(f"🛠️🌐 - {ref} Sysadmin")
PY
}

#------------------------------------------------------------------------------
# Core operations
#------------------------------------------------------------------------------

# Path to a project's session-history directory:
# ~/.claude/projects/<encoded-workspace>/, where encoded workspace is the
# absolute project path with '/' replaced by '-'.
sessions_dir() {
  local project=$1
  local dir; dir=$(project_dir "$project")
  local encoded="${dir//\//-}"
  printf '%s' "${CLAUDE_HOME}/.claude/projects/${encoded}"
}

# Most recently modified session file (.jsonl) for a project's workspace.
latest_session_id() {
  local project=$1
  local sdir; sdir=$(sessions_dir "$project")
  [[ -d "$sdir" ]] || return 1
  ls -t "$sdir"/*.jsonl 2>/dev/null | head -1 | xargs -I{} basename {} .jsonl
}

# Resolve a (possibly truncated) session id to a full UUID by prefix match
# against ~/.claude/projects/<encoded>/*.jsonl. Exits non-zero on miss/ambiguity.
resolve_session_id() {
  local project=$1
  local query=$2
  local sdir; sdir=$(sessions_dir "$project")
  [[ -d "$sdir" ]] || return 1
  # Exact match first
  if [[ -f "$sdir/$query.jsonl" ]]; then
    printf '%s' "$query"
    return 0
  fi
  local matches
  mapfile -t matches < <(find "$sdir" -maxdepth 1 -name "${query}*.jsonl" 2>/dev/null)
  case ${#matches[@]} in
    0) return 1 ;;
    1) basename "${matches[0]}" .jsonl ;;
    *) printf 'ambiguous: %d sessions match prefix %s\n' "${#matches[@]}" "$query" >&2; return 2 ;;
  esac
}

# Emit JSON array of session metadata for a project. Each item:
#   { sid, mtime, mtime_h, msgs, preview }
list_sessions_json() {
  local project=$1
  local sdir; sdir=$(sessions_dir "$project")
  python3 - "$sdir" <<'PY'
import json, sys
from pathlib import Path
from datetime import datetime
sdir = Path(sys.argv[1])
out = []
if sdir.is_dir():
    files = sorted(sdir.glob('*.jsonl'), key=lambda p: p.stat().st_mtime, reverse=True)
    for f in files:
        sid = f.stem
        st = f.stat()
        mtime = datetime.fromtimestamp(st.st_mtime)
        preview = ""
        msgs = 0
        try:
            with open(f, encoding="utf-8", errors="replace") as fh:
                for line in fh:
                    msgs += 1
                    if preview:
                        continue
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    if obj.get("type") != "user":
                        continue
                    content = obj.get("message", {}).get("content", "")
                    if isinstance(content, list):
                        for c in content:
                            if isinstance(c, dict) and c.get("type") == "text":
                                preview = c.get("text", "") or ""
                                break
                    elif isinstance(content, str):
                        preview = content
        except Exception:
            pass
        preview = " ".join(preview.split())
        if len(preview) > 70:
            preview = preview[:67] + "..."
        out.append({
            "sid": sid,
            "mtime": mtime.isoformat(timespec="seconds"),
            "mtime_h": mtime.strftime("%Y-%m-%d %H:%M"),
            "msgs": msgs,
            "preview": preview,
        })
print(json.dumps(out))
PY
}

start_tmux() {
  local project=$1
  local dir; dir=$(project_dir "$project")
  local session; session=$(project_session "$project")

  project_exists "$project" || die "project '$project' not found at $dir"

  if session_running "$session"; then
    say "${c_yellow}~${c_reset} $session already running"
    return 0
  fi

  local label; label=$(session_label "$project")
  # POSIX-safe quoting for the label inside the sh -c string tmux runs.
  local label_esc; label_esc=$(python3 -c 'import shlex, sys; print(shlex.quote(sys.argv[1]))' "$label")

  logmsg "starting $session ($dir) — label: $label"
  # Top-level --remote-control flag (single-session mode) — required so that
  # 'resume' (which combines -r/--continue with --remote-control) works on
  # the same CLI. The 'claude remote-control' SUBCOMMAND is a multi-session
  # daemon but has no --continue/--resume support, so sessions disappear from
  # the picker on restart. Capacity drops to 1, which is fine for the
  # phone-driven single-user case.
  sudo -u "$CLAUDE_USER" tmux new-session -d -s "$session" -c "$dir" \
    "$CLAUDE_HOME/.local/bin/claude --remote-control -n $label_esc"

  # Give tmux a moment to register the session.
  sleep 0.5
  if session_running "$session"; then
    say "${c_green}✓${c_reset} started $session (\"$label\")"
    logmsg "started $session"
  else
    logmsg "failed to start $session"
    die "tmux session $session did not come up — check 'sudo -u $CLAUDE_USER tmux ls'"
  fi
}

# Resume a prior session for a project under Remote Control.
# Usage: start_tmux_resume <project> [session_id]
#   - With session_id: resumes that specific session. Accepts a full UUID or a
#     unique prefix. If the project's tmux session is already running, it is
#     killed first (stop-and-swap), since RC is single-session mode.
#   - Without: resumes the latest session.
# Falls back to start_tmux (fresh) when no prior session exists.
start_tmux_resume() {
  local project=$1
  local explicit_sid=${2:-}
  local dir; dir=$(project_dir "$project")
  local session; session=$(project_session "$project")

  project_exists "$project" || die "project '$project' not found at $dir"

  local sid
  if [[ -n "$explicit_sid" ]]; then
    if ! sid=$(resolve_session_id "$project" "$explicit_sid"); then
      die "no session matching '$explicit_sid' found for project '$project' (check 'claude-remote sessions $project')"
    fi
  else
    sid=$(latest_session_id "$project" 2>/dev/null || true)
    if [[ -z "$sid" ]]; then
      say "${c_yellow}!${c_reset} no prior session found for $project — falling back to fresh start"
      start_tmux "$project"
      return $?
    fi
  fi

  if session_running "$session"; then
    if [[ -n "$explicit_sid" ]]; then
      say "${c_blue}==>${c_reset} stopping $session to swap to session ${sid:0:8}"
      logmsg "stopping $session to swap to $sid"
      sudo -u "$CLAUDE_USER" tmux kill-session -t "$session"
      sleep 0.3
    else
      say "${c_yellow}~${c_reset} $session already running"
      return 0
    fi
  fi

  local label; label=$(session_label "$project")
  local label_esc; label_esc=$(python3 -c 'import shlex, sys; print(shlex.quote(sys.argv[1]))' "$label")

  logmsg "resuming $session ($dir) — sid: $sid — label: $label"
  # -r <uuid> --remote-control -n <label> '' — the trailing empty-string
  # positional satisfies the CLI's "prompt required when resuming under
  # remote-control" check without actually pushing a new user message.
  sudo -u "$CLAUDE_USER" tmux new-session -d -s "$session" -c "$dir" \
    "$CLAUDE_HOME/.local/bin/claude -r $sid --remote-control -n $label_esc ''"

  sleep 0.5
  if session_running "$session"; then
    say "${c_green}✓${c_reset} resumed $session (\"$label\", sid ${sid:0:8})"
    logmsg "resumed $session"
  else
    logmsg "failed to resume $session"
    die "tmux session $session did not come up — check 'sudo -u $CLAUDE_USER tmux ls'"
  fi
}

stop_tmux() {
  local project=$1
  local session; session=$(project_session "$project")
  if session_running "$session"; then
    logmsg "stopping $session"
    sudo -u "$CLAUDE_USER" tmux kill-session -t "$session"
    say "${c_green}✓${c_reset} stopped $session"
  else
    say "${c_yellow}~${c_reset} $session not running"
  fi
}

#------------------------------------------------------------------------------
# Commands
#------------------------------------------------------------------------------

cmd_list() {
  ensure_state
  printf '%-20s %-10s %-10s %s\n' "PROJECT" "DESIRED" "ACTUAL" "LAST_STARTED"

  local projects
  projects=$( { discover_projects; state_projects; } | sort -u )
  if [[ -z "$projects" ]]; then
    say "  (no projects on this relay yet — provision one via server-sysadmin)"
    return
  fi

  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    local desired actual last
    desired=$(state_get "$p" desired_state)
    [[ -z "$desired" ]] && desired="-"
    if session_running "$(project_session "$p")"; then
      actual="running"
    else
      actual="stopped"
    fi
    last=$(state_get "$p" last_started)
    [[ -z "$last" ]] && last="-"

    if [[ "$desired" == "running" && "$actual" != "running" ]]; then
      printf '%s%-20s %-10s %-10s %s%s\n' "$c_red" "$p" "$desired" "$actual" "$last" "$c_reset"
    elif [[ "$desired" == "stopped" && "$actual" == "running" ]]; then
      printf '%s%-20s %-10s %-10s %s%s\n' "$c_yellow" "$p" "$desired" "$actual" "$last" "$c_reset"
    else
      printf '%-20s %-10s %-10s %s\n' "$p" "$desired" "$actual" "$last"
    fi
  done <<< "$projects"

  # Root session footer (only if tracked or currently running)
  local root_desired root_actual root_last
  root_desired=$(root_state_get desired_state)
  if root_session_running; then root_actual="running"; else root_actual="stopped"; fi
  if [[ -n "$root_desired" || "$root_actual" == "running" ]]; then
    [[ -z "$root_desired" ]] && root_desired="(untracked)"
    root_last=$(root_state_get last_started); [[ -z "$root_last" ]] && root_last="-"
    echo
    if [[ "$root_desired" == "running" && "$root_actual" != "running" ]]; then
      printf '%s%-20s %-10s %-10s %s%s\n' "$c_red" "<root>" "$root_desired" "$root_actual" "$root_last" "$c_reset"
    elif [[ "$root_desired" != "running" && "$root_actual" == "running" ]]; then
      printf '%s%-20s %-10s %-10s %s%s\n' "$c_yellow" "<root>" "$root_desired" "$root_actual" "$root_last" "$c_reset"
    else
      printf '%-20s %-10s %-10s %s\n' "<root>" "$root_desired" "$root_actual" "$root_last"
    fi
  fi
}

cmd_status() {
  ensure_state
  local project=${1:-}
  if [[ -z "$project" ]]; then
    cmd_list
    return
  fi
  project_exists "$project" || die "project '$project' not found at $(project_dir "$project")"

  local session dir desired actual last last_stopped last_reconciled
  session=$(project_session "$project")
  dir=$(project_dir "$project")
  desired=$(state_get "$project" desired_state); [[ -z "$desired" ]] && desired="-"
  last=$(state_get "$project" last_started); [[ -z "$last" ]] && last="-"
  last_stopped=$(state_get "$project" last_stopped); [[ -z "$last_stopped" ]] && last_stopped="-"
  last_reconciled=$(state_get "$project" last_reconciled); [[ -z "$last_reconciled" ]] && last_reconciled="-"
  if session_running "$session"; then actual="running"; else actual="stopped"; fi

  local label; label=$(session_label "$project")
  cat <<EOF
Project:           $project
Directory:         $dir
Tmux session:      $session
Session label:     $label
Desired state:     $desired
Actual state:      $actual
Last started:      $last
Last stopped:      $last_stopped
Last reconciled:   $last_reconciled
EOF
}

cmd_rename() {
  ensure_state
  local project=${1:-}
  local label=${2:-}
  [[ -n "$project" && -n "$label" ]] || die "usage: claude-remote rename <project> <label>"
  project_exists "$project" || die "project '$project' not found"

  local cfg="$(project_dir "$project")/config.json"
  [[ -f "$cfg" ]] || die "config.json missing at $cfg"

  python3 - "$cfg" "$label" <<'PY'
import json, sys
cfg_path, label = sys.argv[1:]
with open(cfg_path) as f:
    cfg = json.load(f)
cfg["session_label"] = label
with open(cfg_path, "w") as f:
    json.dump(cfg, f, indent=2)
PY
  say "${c_green}✓${c_reset} session_label set in $cfg"
  say "Restart the project to apply: claude-remote restart $project"
}

cmd_start() {
  ensure_state
  local project=${1:-}
  [[ -n "$project" ]] || die "usage: claude-remote start <project>"
  state_update "$project" desired_state=running last_started="$(ts)"
  start_tmux "$project"
}

cmd_resume() {
  ensure_state
  local project=${1:-}
  local sid=${2:-}
  [[ -n "$project" ]] || die "usage: claude-remote resume <project> [session_id]"
  state_update "$project" desired_state=running last_started="$(ts)"
  start_tmux_resume "$project" "$sid"
}

cmd_sessions() {
  ensure_state
  local project=${1:-}
  [[ -n "$project" ]] || die "usage: claude-remote sessions <project>"
  project_exists "$project" || die "project '$project' not found at $(project_dir "$project")"

  local json
  json=$(list_sessions_json "$project")
  local count
  count=$(printf '%s' "$json" | python3 -c 'import json,sys; print(len(json.load(sys.stdin)))')

  if [[ "$count" -eq 0 ]]; then
    say "${c_yellow}No prior sessions for project '$project'.${c_reset}"
    say "Start a fresh one: claude-remote start $project"
    return 0
  fi

  say "Sessions for ${c_blue}$project${c_reset} (most recent first):"
  echo
  printf '%-4s %-10s %-16s %-6s %s\n' "#" "ID" "WHEN" "MSGS" "FIRST USER MESSAGE"
  # Pass JSON via argv (not pipe) — a heredoc-supplied script can't also read
  # from a piped stdin: the `<<` redirect overrides the pipe, so json.load
  # would see empty input.
  python3 - "$json" <<'PY'
import json, sys
data = json.loads(sys.argv[1])
for i, s in enumerate(data, 1):
    print(f"{i:<4} {s['sid'][:8]:<10} {s['mtime_h']:<16} {s['msgs']:<6} {s['preview']}")
PY

  # Only prompt to pick if both stdin and stdout are TTYs (interactive use).
  # Slash commands / scripts get the table back and call resume themselves.
  if [[ -t 0 && -t 1 ]]; then
    echo
    local choice
    read -r -p "Pick a session number to resume (Enter to cancel): " choice || return 0
    [[ -z "$choice" ]] && { say "(cancelled)"; return 0; }
    [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid selection: $choice"
    (( choice >= 1 && choice <= count )) || die "out of range: $choice (have $count)"

    local chosen_sid
    chosen_sid=$(printf '%s' "$json" | python3 -c "import json, sys; print(json.load(sys.stdin)[$((choice - 1))]['sid'])")
    echo
    cmd_resume "$project" "$chosen_sid"
  else
    echo
    say "To resume a specific session: claude-remote resume $project <id>"
    say "(IDs can be the 8-char prefix shown above as long as it's unique)"
  fi
}

cmd_stop() {
  ensure_state
  local project=${1:-}
  [[ -n "$project" ]] || die "usage: claude-remote stop <project>"
  state_update "$project" desired_state=stopped last_stopped="$(ts)"
  stop_tmux "$project"
}

cmd_restart() {
  local project=${1:-}
  [[ -n "$project" ]] || die "usage: claude-remote restart <project>"
  cmd_stop "$project"
  cmd_start "$project"
}

# delete — built up incrementally. Currently implements only step 1:
# stop the session if it's running. Subsequent steps will add: remove the
# project directory, clear its state entry, optionally clean up session
# history, and optionally remove the project's pubkey from each host's
# authorized_keys.
cmd_delete() {
  ensure_state
  local project=${1:-}
  [[ -n "$project" ]] || die "usage: claude-remote delete <project>"

  local dir; dir=$(project_dir "$project")
  local session; session=$(project_session "$project")
  local has_dir=0 has_state=0
  [[ -d "$dir" ]] && has_dir=1
  [[ -n "$(state_get "$project" desired_state)" || -n "$(state_get "$project" last_started)" ]] && has_state=1

  if [[ $has_dir -eq 0 && $has_state -eq 0 ]] && ! session_running "$session"; then
    die "no trace of project '$project' (no dir, no state, no session)"
  fi

  say "${c_blue}==>${c_reset} delete plan for '$project'"
  if [[ $has_dir -eq 1 ]]; then
    say "    directory:    $dir   ${c_yellow}(will be removed in step 2)${c_reset}"
  else
    say "    directory:    (already gone)"
  fi
  if session_running "$session"; then
    say "    tmux session: $session   ${c_blue}(running — will stop now)${c_reset}"
  else
    say "    tmux session: $session   (not running)"
  fi
  if [[ $has_state -eq 1 ]]; then
    say "    state.json:   projects.$project   ${c_yellow}(will be removed in step 3)${c_reset}"
  else
    say "    state.json:   (no entry)"
  fi
  echo

  # Step 1: stop the session if it's running.
  if session_running "$session"; then
    say "${c_blue}==>${c_reset} step 1: stopping session"
    cmd_stop "$project"
  else
    say "${c_yellow}~${c_reset} step 1: session not running, nothing to stop"
  fi

  echo
  say "${c_yellow}!${c_reset} delete is partial — step 1 only. Steps 2-5 not yet implemented:"
  say "    2. rm -rf $dir"
  say "    3. drop projects.$project from state.json"
  say "    4. (optional) rm -rf ~/.claude/projects/${dir//\//-}/   # session history"
  say "    5. (optional) remove this project's pubkey from each host's authorized_keys"
}

cmd_reconcile() {
  ensure_state
  local drift=0 total=0

  # --- Root session reconcile (opt-in: only if state.root.desired_state=running)
  local root_desired
  root_desired=$(root_state_get desired_state)
  if [[ "$root_desired" == "running" ]]; then
    total=$((total + 1))
    if ! root_session_running; then
      drift=$((drift + 1))
      logmsg "reconcile: root desired=running but session down — resuming"
      local rsid; rsid=$(root_latest_session_id 2>/dev/null || true)
      if start_root_tmux "$rsid"; then
        root_state_update last_reconciled="$(ts)" last_started="$(ts)"
      else
        logmsg "reconcile: root resume failed"
      fi
    fi
  fi

  # --- Projects
  for p in $(state_projects); do
    total=$((total + 1))
    local desired
    desired=$(state_get "$p" desired_state)
    [[ "$desired" != "running" ]] && continue
    if session_running "$(project_session "$p")"; then
      continue
    fi
    drift=$((drift + 1))
    logmsg "reconcile: $p desired=running but session down — resuming"
    if start_tmux_resume "$p"; then
      state_update "$p" last_reconciled="$(ts)" last_started="$(ts)"
    else
      logmsg "reconcile: $p resume failed"
    fi
  done
  if [[ $drift -eq 0 ]]; then
    logmsg "reconcile: ok ($total tracked, no drift)"
  fi
}

#------------------------------------------------------------------------------
# Root (operator) session — opt-in persistence
#------------------------------------------------------------------------------

root_state_get() {
  python3 - "$STATE_FILE" "$1" <<'PY'
import json, sys
state_file, key = sys.argv[1:]
with open(state_file) as f:
    data = json.load(f)
print(data.get("root", {}).get(key, ""))
PY
}

root_state_update() {
  python3 - "$STATE_FILE" "$@" <<'PY'
import json, sys
state_file, *kvs = sys.argv[1:]
with open(state_file) as f:
    data = json.load(f)
root = data.setdefault("root", {})
for kv in kvs:
    k, _, v = kv.partition("=")
    if v == "__delete__":
        root.pop(k, None)
    else:
        root[k] = v
with open(state_file, "w") as f:
    json.dump(data, f, indent=2, sort_keys=True)
PY
}

root_label() {
  local label; label=$(root_state_get label)
  [[ -z "$label" ]] && label="$ROOT_DEFAULT_LABEL"
  printf '%s' "$label"
}

root_session_running() {
  tmux has-session -t "$ROOT_SESSION" 2>/dev/null
}

# /root encodes to "-root" under ~/.claude/projects/
root_sessions_dir() { printf '%s' "/root/.claude/projects/-root"; }

root_latest_session_id() {
  local sdir; sdir=$(root_sessions_dir)
  [[ -d "$sdir" ]] || return 1
  ls -t "$sdir"/*.jsonl 2>/dev/null | head -1 | xargs -I{} basename {} .jsonl
}

root_resolve_session_id() {
  local query=$1
  local sdir; sdir=$(root_sessions_dir)
  [[ -d "$sdir" ]] || return 1
  if [[ -f "$sdir/$query.jsonl" ]]; then
    printf '%s' "$query"
    return 0
  fi
  mapfile -t matches < <(find "$sdir" -maxdepth 1 -name "${query}*.jsonl" 2>/dev/null)
  case ${#matches[@]} in
    0) return 1 ;;
    1) basename "${matches[0]}" .jsonl ;;
    *) printf 'ambiguous: %d sessions match prefix %s\n' "${#matches[@]}" "$query" >&2; return 2 ;;
  esac
}

list_root_sessions_json() {
  local sdir; sdir=$(root_sessions_dir)
  python3 - "$sdir" <<'PY'
import json, sys
from pathlib import Path
from datetime import datetime
sdir = Path(sys.argv[1])
out = []
if sdir.is_dir():
    files = sorted(sdir.glob('*.jsonl'), key=lambda p: p.stat().st_mtime, reverse=True)
    for f in files:
        sid = f.stem
        st = f.stat()
        mtime = datetime.fromtimestamp(st.st_mtime)
        preview = ""
        msgs = 0
        try:
            with open(f, encoding="utf-8", errors="replace") as fh:
                for line in fh:
                    msgs += 1
                    if preview:
                        continue
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    if obj.get("type") != "user":
                        continue
                    content = obj.get("message", {}).get("content", "")
                    if isinstance(content, list):
                        for c in content:
                            if isinstance(c, dict) and c.get("type") == "text":
                                preview = c.get("text", "") or ""
                                break
                    elif isinstance(content, str):
                        preview = content
        except Exception:
            pass
        preview = " ".join(preview.split())
        if len(preview) > 70:
            preview = preview[:67] + "..."
        out.append({
            "sid": sid,
            "mtime_h": mtime.strftime("%Y-%m-%d %H:%M"),
            "msgs": msgs,
            "preview": preview,
        })
print(json.dumps(out))
PY
}

# start_root_tmux [session_id]
#   - With sid: resume that session (stops current if a different one is up)
#   - Without sid: start a fresh session
start_root_tmux() {
  local explicit_sid=${1:-}
  [[ -x "$ROOT_CLAUDE_BIN" ]] \
    || die "claude not installed for root at $ROOT_CLAUDE_BIN — run the installer as root first"

  local sid=""
  if [[ -n "$explicit_sid" ]]; then
    if ! sid=$(root_resolve_session_id "$explicit_sid"); then
      die "no root session matching '$explicit_sid' (check 'claude-remote root sessions')"
    fi
  fi

  if root_session_running; then
    if [[ -n "$sid" ]]; then
      say "${c_blue}==>${c_reset} stopping $ROOT_SESSION to swap to ${sid:0:8}"
      logmsg "stopping $ROOT_SESSION to swap to $sid"
      tmux kill-session -t "$ROOT_SESSION"
      sleep 0.3
    else
      say "${c_yellow}~${c_reset} $ROOT_SESSION already running"
      return 0
    fi
  fi

  local label; label=$(root_label)
  local label_esc; label_esc=$(python3 -c 'import shlex, sys; print(shlex.quote(sys.argv[1]))' "$label")

  logmsg "starting $ROOT_SESSION — label: $label sid: ${sid:-fresh}"
  if [[ -n "$sid" ]]; then
    tmux new-session -d -s "$ROOT_SESSION" -c "$ROOT_DIR" \
      "$ROOT_CLAUDE_BIN -r $sid --remote-control -n $label_esc ''"
  else
    tmux new-session -d -s "$ROOT_SESSION" -c "$ROOT_DIR" \
      "$ROOT_CLAUDE_BIN --remote-control -n $label_esc"
  fi

  sleep 0.5
  if root_session_running; then
    say "${c_green}✓${c_reset} started $ROOT_SESSION (\"$label\"${sid:+, sid ${sid:0:8}})"
    logmsg "started $ROOT_SESSION"
  else
    die "$ROOT_SESSION did not come up — check 'tmux ls'"
  fi
}

stop_root_tmux() {
  if root_session_running; then
    logmsg "stopping $ROOT_SESSION"
    tmux kill-session -t "$ROOT_SESSION"
    say "${c_green}✓${c_reset} stopped $ROOT_SESSION"
  else
    say "${c_yellow}~${c_reset} $ROOT_SESSION not running"
  fi
}

cmd_root_status() {
  local desired actual last last_stopped last_reconciled label
  desired=$(root_state_get desired_state); [[ -z "$desired" ]] && desired="-"
  if root_session_running; then actual="running"; else actual="stopped"; fi
  last=$(root_state_get last_started); [[ -z "$last" ]] && last="-"
  last_stopped=$(root_state_get last_stopped); [[ -z "$last_stopped" ]] && last_stopped="-"
  last_reconciled=$(root_state_get last_reconciled); [[ -z "$last_reconciled" ]] && last_reconciled="-"
  label=$(root_label)

  cat <<EOF
Root session
  Tmux session:      $ROOT_SESSION
  Working directory: $ROOT_DIR
  Session label:     $label
  Desired state:     $desired   (cron-reconcile resumes on crash if "running")
  Actual state:      $actual
  Last started:      $last
  Last stopped:      $last_stopped
  Last reconciled:   $last_reconciled
EOF
}

cmd_root_start() {
  root_state_update desired_state=running last_started="$(ts)"
  start_root_tmux ""
}

cmd_root_resume() {
  local sid=${1:-}
  root_state_update desired_state=running last_started="$(ts)"
  if [[ -n "$sid" ]]; then
    start_root_tmux "$sid"
  else
    local latest; latest=$(root_latest_session_id 2>/dev/null || true)
    if [[ -z "$latest" ]]; then
      say "${c_yellow}!${c_reset} no prior root session found — starting fresh"
      start_root_tmux ""
    else
      start_root_tmux "$latest"
    fi
  fi
}

cmd_root_stop() {
  root_state_update desired_state=stopped last_stopped="$(ts)"
  stop_root_tmux
}

cmd_root_restart() {
  cmd_root_stop
  cmd_root_start
}

cmd_root_rename() {
  local label=${1:-}
  [[ -n "$label" ]] || die "usage: claude-remote root rename <label>"
  root_state_update label="$label"
  say "${c_green}✓${c_reset} root session label set"
  say "Restart root to apply: claude-remote root restart"
}

cmd_root_sessions() {
  local json count
  json=$(list_root_sessions_json)
  count=$(python3 -c 'import json,sys; print(len(json.loads(sys.argv[1])))' "$json")

  if [[ "$count" -eq 0 ]]; then
    say "${c_yellow}No prior root sessions.${c_reset}"
    say "Start a fresh one: claude-remote root start"
    return 0
  fi

  say "Root sessions (most recent first):"
  echo
  printf '%-4s %-10s %-16s %-6s %s\n' "#" "ID" "WHEN" "MSGS" "FIRST USER MESSAGE"
  # Pass JSON via argv (heredoc redirect overrides any pipe — sys.stdin would
  # be empty if we used `printf | python3 - <<'PY'`).
  python3 - "$json" <<'PY'
import json, sys
for i, s in enumerate(json.loads(sys.argv[1]), 1):
    print(f"{i:<4} {s['sid'][:8]:<10} {s['mtime_h']:<16} {s['msgs']:<6} {s['preview']}")
PY

  if [[ -t 0 && -t 1 ]]; then
    echo
    local choice
    read -r -p "Pick a session number to resume (Enter to cancel): " choice || return 0
    [[ -z "$choice" ]] && { say "(cancelled)"; return 0; }
    [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid selection: $choice"
    (( choice >= 1 && choice <= count )) || die "out of range: $choice (have $count)"

    local chosen_sid
    chosen_sid=$(python3 -c "import json, sys; print(json.loads(sys.argv[1])[$((choice-1))]['sid'])" "$json")
    echo
    cmd_root_resume "$chosen_sid"
  else
    echo
    say "To resume a specific session: claude-remote root resume <id>"
  fi
}

cmd_root() {
  ensure_state
  local sub=${1:-status}; shift || true
  case "$sub" in
    status)    cmd_root_status "$@" ;;
    start)     cmd_root_start "$@" ;;
    resume)    cmd_root_resume "$@" ;;
    stop)      cmd_root_stop "$@" ;;
    restart)   cmd_root_restart "$@" ;;
    sessions)  cmd_root_sessions "$@" ;;
    rename)    cmd_root_rename "$@" ;;
    -h|--help|help)
      cat <<EOF
Usage: claude-remote root <subcommand> [args]

Subcommands:
  status                Show current root session state (running, desired, label)
  start                 Mark desired=running and start tmux (fresh session)
  resume [sid]          Mark desired=running and resume (latest or specific sid)
  stop                  Mark desired=stopped and kill tmux
  restart               Stop then start (fresh)
  sessions              List prior root Claude sessions; interactive picker if TTY
  rename <label>        Set the Remote Control session label (stored in state.json)

Persistence: by default the root session is NOT tracked — running 'root start'
or 'root resume' enrolls it (sets state.root.desired_state=running) so the
cron reconciler will bring it back if it crashes. 'root stop' disenrolls it.
EOF
      ;;
    *) die "unknown root subcommand: $sub (try 'claude-remote root --help')" ;;
  esac
}

cmd_install() {
  require_root
  ensure_state

  local self; self=$(readlink -f "$0")
  local skill_dir; skill_dir=$(dirname "$(dirname "$self")")
  local cmds_src="$skill_dir/commands"
  local cmds_dst="/root/.claude/commands"

  chmod +x "$self"
  ln -sfn "$self" /usr/local/bin/claude-remote
  say "${c_green}✓${c_reset} /usr/local/bin/claude-remote -> $self"

  install -d -m 0750 "$cmds_dst"
  if [[ -d "$cmds_src" ]]; then
    local n=0
    for f in "$cmds_src"/*.md; do
      [[ -f "$f" ]] || continue
      ln -sfn "$f" "$cmds_dst/$(basename "$f")"
      n=$((n + 1))
    done
    say "${c_green}✓${c_reset} symlinked $n slash command(s) into $cmds_dst"
  fi

  cat <<EOF

State directory:   $STATE_DIR
State file:        $STATE_FILE
Log file:          $LOG_FILE

To enable automatic monitoring (every 5 minutes), add this cron entry as root:
    */5 * * * * /usr/local/bin/claude-remote reconcile

Or install it now (you'll be prompted by your shell, since this script won't touch crontab without explicit consent):
    (crontab -l 2>/dev/null | grep -v '/claude-remote reconcile'; \\
     echo '*/5 * * * * /usr/local/bin/claude-remote reconcile') | crontab -
EOF
}

#------------------------------------------------------------------------------
# Dispatch
#------------------------------------------------------------------------------

require_root

case "${1:-list}" in
  list)        shift || true; cmd_list "$@" ;;
  status)      shift; cmd_status "$@" ;;
  sessions)    shift; cmd_sessions "$@" ;;
  start)       shift; cmd_start "$@" ;;
  resume)      shift; cmd_resume "$@" ;;
  stop)        shift; cmd_stop "$@" ;;
  restart)     shift; cmd_restart "$@" ;;
  delete)      shift; cmd_delete "$@" ;;
  rename)      shift; cmd_rename "$@" ;;
  reconcile)   shift || true; cmd_reconcile "$@" ;;
  install)     shift || true; cmd_install "$@" ;;
  root)        shift || true; cmd_root "$@" ;;
  -h|--help|help)
    cat <<EOF
Usage: claude-remote <command> [args]

Commands:
  list                          List all projects with desired and actual states (default)
  status [project]              Show detailed status (falls back to list if no project)
  sessions <project>            List prior Claude sessions for a project; when run
                                interactively, prompts to pick one and resumes it
                                (stopping the current session if one is up)
  start <project>               Mark desired=running and start tmux (fresh session)
  resume <project> [sid]        Mark desired=running and resume a session. With no
                                sid, picks the latest. With an sid (full UUID or
                                unique 8-char prefix), resumes that specific one —
                                stops the current session first if it's running.
  stop <project>                Mark desired=stopped and kill tmux session
  restart <project>             Stop then start (fresh)
  delete <project>              Remove a project. INCOMPLETE — step 1 only:
                                stops the session and prints what later steps
                                will remove (dir, state, history, remote keys).
  rename <project> <label>      Set the Remote Control session label in config.json
  reconcile                     For any desired=running project whose session is
                                down, bring it back via 'resume' (intended for
                                cron, every few minutes)
  install                       Symlink the CLI and slash commands; create state dir
  root <subcommand>             Manage the root (operator) session — opt-in
                                persistence. See 'claude-remote root --help'.
EOF
    ;;
  *) die "unknown command: $1 (try --help)" ;;
esac
